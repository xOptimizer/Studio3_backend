            },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout-all",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "logout-all"
              ]
            },
            "description": "Log out from all sessions/devices. Protected route (requires Bearer accessToken)."
          },
          "response": []
        },
