              "raw": "{{baseUrl}}/api/auth/username/check?username={{username}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "username", "check"],
              "query": [
                { "key": "username", "value": "{{username}}" },
                { "key": "for_user_id", "value": "me", "disabled": true }
