          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Sunset Study\",\n  \"mediaUrl\": \"/{{username}}/pieces/sample/original.jpg\",\n  \"mediaType\": \"image\",\n  \"caption\": \"Oil on canvas\",\n  \"medium\": \"painting\",\n  \"isForSale\": false\n}"
