# Copy to .env.development / .env.production. Do not commit secrets.

PORT=9000
FLASK_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/flask_app_dev

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRY_MINUTES=15
SALT_ROUNDS=10
SECRET_KEY=change-me-in-production

# SMTP (optional — OTP emails skipped when unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

FRONTEND_URL=http://localhost:3000

# AWS S3 (optional — when S3_BUCKET is empty, presign returns dev placeholder URLs)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=
S3_PUBLIC_BASE_URL=

# Firebase Cloud Messaging (push notifications — optional, skipped when unset)
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_SERVICE_ACCOUNT_JSON=

# Stripe (placeholder — payment integration not yet built; leave unset)
STRIPE_SECRET_KEY=
