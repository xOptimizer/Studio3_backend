# Copy to .env and .env.development / .env.production. Do not commit secrets.

PORT=9000
FLASK_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/flask_app_dev

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=change-me-in-production
SALT_ROUNDS=10

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
BACKEND_URL=http://localhost:9000
FRONTEND_URL=http://localhost:3000
OAUTH_SUCCESS_PATH=/auth/callback

# CORS / frontend
FRONTEND_URL=http://localhost:3000

# Production
SECRET_KEY=change-me-in-production
